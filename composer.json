{
    "name": "fabianternis/google-agent-platform-php",
    "version": "0.5.0",
    "description": "A lightweight, dependency-free PHP wrapper for the Google Agent Platform (formerly Vertex AI) — supports Gemini, Claude (Anthropic), Veo video, Imagen images, TTS, and file uploads.",
    "type": "library",
    "license": "Apache-2.0",
    "keywords": [
        "google",
        "agent-platform",
        "vertex-ai",
        "gemini",
        "claude",
        "anthropic",
        "veo",
        "imagen",
        "tts",
        "text-to-speech",
        "file-upload",
        "ai",
        "llm",
        "multimodal"
    ],
    "autoload": {
        "psr-4": {
            "GoogleAgentPlatform\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Fabian Ternis",
            "email": "f.ternis@xpsystems.eu"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-fileinfo": "*"
    }
}
