{
    "name": "fabianternis/google-agent-platform-php",
    "version": "0.4.0",
    "description": "A lightweight, dependency-free PHP wrapper for the Google Agent Platform (formerly Vertex AI) — supports Gemini, Claude (Anthropic), Veo video generation, and TTS models.",
    "type": "library",
    "license": "Apache-2.0",
    "keywords": [
        "google",
        "agent-platform",
        "vertex-ai",
        "gemini",
        "claude",
        "anthropic",
        "veo",
        "tts",
        "text-to-speech",
        "ai",
        "llm"
    ],
    "autoload": {
        "psr-4": {
            "GoogleAgentPlatform\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Fabian Ternis",
            "email": "f.ternis@xpsystems.eu"
        }
    ],
    "require": {
        "php": ">=8.0",
        "ext-curl": "*",
        "ext-json": "*"
    }
}
